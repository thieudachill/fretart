{
  "name": "fretart",
  "version": "0.1.0",
  "description": "Real-time generative visuals driven by a guitarist's hands — webcam finger tracking rendered as ink, print, and string art.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thieudachill/fretart.git"
  },
  "homepage": "https://github.com/thieudachill/fretart#readme",
  "bugs": "https://github.com/thieudachill/fretart/issues",
  "keywords": [
    "guitar",
    "generative-art",
    "hand-tracking",
    "mediapipe",
    "threejs",
    "creative-coding",
    "music-visualization"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "postinstall": "node scripts/setup-assets.mjs"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.22",
    "three": "^0.180.0",
    "tweakpane": "^4.0.5"
  },
  "devDependencies": {
    "@tweakpane/core": "^2.0.5",
    "@types/three": "^0.180.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.0"
  }
}
